view,
text,
image {
  box-sizing: border-box;
}

.class-table-content-item text {
  display: block;
}

.class-table-box {
  position: relative;
  overflow: hidden;
  padding: 0 0 20rpx;
  border-radius: 20rpx;
  background-color: var(--card, #ffffff);
}

.class-table-box .left-bg {
  position: absolute;
  z-index: 10;
  top: 84rpx;
  left: 0;
  width: 64rpx;
  height: 100%;
  border-right: 1rpx solid var(--border, #e4e4e7);
  background: var(--card, #ffffff);
}

.class-table-box .top-bg {
  position: absolute;
  z-index: 10;
  top: 0;
  left: 0;
  width: 100%;
  height: 84rpx;
  border-bottom: 1rpx solid var(--border, #e4e4e7);
  background: var(--card, #ffffff);
}

.class-table-box .class-table-background {
  position: absolute;
  z-index: 1;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
}

.class-table-box .class-table-background.scale {
  transform: scale(1.1);
}

.class-table-box .class-table-date-list {
  position: relative;
  z-index: 100;
  display: flex;
  height: 84rpx;
  text-align: center;
}

.class-table-box .class-table-date-list .class-table-date-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  padding: 10rpx 0;
  text-align: center;
}

.class-table-box .class-table-date-list .class-table-date-item.month {
  flex: initial;
  width: 64rpx;
  border-right: 1rpx solid var(--border, #e4e4e7);
  color: var(--muted-foreground, #71717a);
  font-size: 24rpx;
}

.class-table-box .class-table-date-list .class-table-date-item .class-table-date-item-day {
  color: var(--foreground, #09090b);
  font-size: 24rpx;
  font-weight: 700;
}

.class-table-box .class-table-date-list .class-table-date-item .class-table-date-item-date {
  color: var(--muted-foreground, #71717a);
  font-size: 20rpx;
}

.class-table-box .class-table-date-list .class-table-date-item.today .class-table-date-item-day,
.class-table-box .class-table-date-list .class-table-date-item.today .class-table-date-item-date {
  color: var(--primary, #2563eb);
  font-weight: 700;
}

.class-table-box .class-table-content {
  position: relative;
  z-index: 100;
  display: flex;
  width: 100%;
}

.class-table-box .class-table-content .class-table-content-left {
  display: flex;
  flex-direction: column;
  width: 64rpx;
}

.class-table-box .class-table-content .class-table-content-right {
  position: relative;
  flex: 1;
  height: 100%;
}

.class-table-box .class-table-content .class-table-content-left-section {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  text-align: center;
  font-size: 24rpx;
}

.class-table-box .class-table-content .class-table-content-left-section .time {
  color: var(--muted-foreground, #71717a);
  font-size: 16rpx;
}

.class-table-box .class-table-content .class-table-content-left-section .text {
  margin-bottom: 8rpx;
  color: var(--foreground, #09090b);
  font-weight: 700;
}

.class-table-content-line {
  position: absolute;
  width: 100%;
  height: 1rpx;
  background-color: var(--border, #e4e4e7);
}

.class-table-content-item-box {
  position: absolute;
  padding: 2rpx;
}

.class-table-content-item {
  position: relative;
  height: 100%;
  overflow: hidden;
  border-radius: 2rpx;
  padding: 8rpx;
}

.class-table-content-item .class-table-content-item-remark {
  margin-bottom: 8rpx;
  font-size: 16rpx;
  line-height: 1.5;
}

.class-table-content-item .class-table-content-item-name {
  margin-bottom: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.5;
}

.class-table-content-item .class-table-content-item-teacher,
.class-table-content-item .class-table-content-item-place {
  font-size: 18rpx;
  line-height: 1.5;
}

.class-table-content-item .class-table-content-item-place {
  margin-bottom: 8rpx;
}

.class-table-content-item .item-overlap {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  left: 8rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: currentColor;
  opacity: 0.5;
}

