.page {
  --background: #f6f6f6;
  --foreground: #09090b;
  --card: #ffffff;
  --card-foreground: #09090b;
  --primary: #2563eb;
  --primary-foreground: #fafafa;
  --muted: #f4f4f5;
  --muted-foreground: #71717a;
  --border: #e4e4e7;

  min-height: 100vh;
  padding: 24rpx;
  background: var(--background);
}

.page.dark {
  --background: #18181b;
  --foreground: #fafafa;
  --card: #09090b;
  --card-foreground: #fafafa;
  --primary: #3b82f6;
  --primary-foreground: #09090b;
  --muted: #27272a;
  --muted-foreground: #a1a1aa;
  --border: #27272a;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.page-title {
  color: var(--foreground);
  font-size: 36rpx;
  font-weight: 700;
}

.page-description {
  margin-top: 8rpx;
  color: var(--muted-foreground);
  font-size: 24rpx;
  line-height: 1.6;
}

.theme-toggle {
  flex: none;
  border-radius: 999rpx;
  padding: 12rpx 24rpx;
  background: var(--primary);
  color: var(--primary-foreground);
  font-size: 24rpx;
  line-height: 1.4;
}

.theme-toggle::after {
  border: none;
}

